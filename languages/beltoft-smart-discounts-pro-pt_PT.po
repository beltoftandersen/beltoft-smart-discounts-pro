msgstr "Licença desativada localmente. A desativação remota não pôde ser confirmada neste momento."

msgid "License deactivated successfully."
msgstr "Licença desativada com sucesso."

#, php-format
msgid "Smart Discounts Pro: Please <a href=\"%s\">enter your license key</a> to enable Pro features."
msgstr "Smart Discounts Pro: Por favor <a href=\"%s\">introduza a sua chave de licença</a> para ativar as funcionalidades Pro."

#, php-format
msgid "Smart Discounts Pro: License is not activated. <a href=\"%s\">Activate your license</a> to enable Pro features and updates."
msgstr "Smart Discounts Pro: A licença não está ativada. <a href=\"%s\">Ative a sua licença</a> para ativar funcionalidades e atualizações Pro."

#, php-format
msgid "Smart Discounts Pro: License inactive. <a href=\"%s\">Renew your license</a> to receive updates."
msgstr "Smart Discounts Pro: Licença inativa. <a href=\"%s\">Renove a sua licença</a> para receber atualizações."

#, php-format
msgid "Smart Discounts Pro: License is not activated on this domain. <a href=\"%s\">Deactivate your old domain</a> and reactivate here."
msgstr "Smart Discounts Pro: A licença não está ativada neste domínio. <a href=\"%s\">Desative o seu domínio anterior</a> e reative aqui."

#, php-format
msgid "Smart Discounts Pro: License key not found. Please <a href=\"%s\">check your license key</a>."
msgstr "Smart Discounts Pro: Chave de licença não encontrada. Por favor <a href=\"%s\">verifique a sua chave de licença</a>."

msgid "A valid license key is required to download updates."
msgstr "É necessária uma chave de licença válida para transferir atualizações."

msgid "Download failed."
msgstr "Falha na transferência."

msgid "Could not connect to license server to download the update."
msgstr "Não foi possível ligar ao servidor de licenças para transferir a atualização."

msgid "Could not retrieve download URL from license server."
msgstr "Não foi possível obter o URL de transferência do servidor de licenças."

