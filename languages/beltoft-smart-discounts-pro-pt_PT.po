msgstr "Importação concluída. %1$d regra(s) importada(s), %2$d erro(s)."

msgid "Please enter a license key."
msgstr "Por favor introduza uma chave de licença."

msgid "Could not connect to license server. Please try again."
msgstr "Não foi possível ligar ao servidor de licenças. Por favor tente novamente."

msgid "License key not found. Please check and try again."
msgstr "Chave de licença não encontrada. Por favor verifique e tente novamente."

msgid "License endpoint unavailable. Please try again in a moment."
msgstr "Ponto de acesso de licença indisponível. Por favor tente novamente dentro de momentos."

msgid "License activation failed."
msgstr "Falha na ativação da licença."

msgid "License activated successfully."
msgstr "Licença ativada com sucesso."

